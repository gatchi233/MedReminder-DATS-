<?xml version="1.0" encoding="utf-8" ?>
<pages:AuthPage
    x:Class="CareHub.Pages.Desktop.HomePage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:pages="clr-namespace:CareHub.Pages"
    xmlns:model="clr-namespace:CareHub.Models"
    Title="Home"
    BackgroundColor="{StaticResource Homepage_Main_Background}">

    <Grid Padding="16"
          ColumnDefinitions="*,*,*"
          RowDefinitions="Auto,Auto,*"
          ColumnSpacing="16"
          RowSpacing="16">

        <!-- ========== PENDING MAR card (left, spans rows 0-1) ========== -->
        <Border Grid.Row="0" Grid.Column="0" Grid.RowSpan="2"
                Stroke="{StaticResource Homepage_Card_Border}"
                StrokeThickness="1"
                BackgroundColor="{StaticResource Homepage_Card_Background}"
                Padding="12">
            <Border.StrokeShape>
                <RoundRectangle CornerRadius="12"/>
            </Border.StrokeShape>

            <VerticalStackLayout Spacing="8">

                <Grid ColumnDefinitions="*,Auto">
                    <HorizontalStackLayout Spacing="6">
                        <Border Padding="6,3" StrokeThickness="0"
                                BackgroundColor="{StaticResource Alert_Error}">
                            <Border.StrokeShape><RoundRectangle CornerRadius="4"/></Border.StrokeShape>
                            <Label Text="{Binding PendingMarCount, StringFormat='Pending today: {0}'}"
                                   FontSize="11" FontAttributes="Bold"
                                   TextColor="{StaticResource Button_Font_Primary}"/>
                        </Border>
                    </HorizontalStackLayout>

                    <Border Grid.Column="1" StrokeThickness="0" HeightRequest="24"
                            BackgroundColor="{StaticResource Button_Icon_Background}">
                        <Border.StrokeShape><RoundRectangle CornerRadius="4"/></Border.StrokeShape>
                        <Label Text="VIEW MAR" FontSize="9" FontAttributes="Bold"
                               TextColor="{StaticResource Button_Font_Primary}"
                               Padding="8,0"
                               VerticalOptions="Center" HorizontalOptions="Center"/>
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnViewMarClicked"/>
                        </Border.GestureRecognizers>
                    </Border>
                </Grid>

                <!-- Top residents with pending/missed -->
                <CollectionView ItemsSource="{Binding PendingMarTop}"
                                SelectionMode="None">
                    <CollectionView.EmptyView>
                        <Label Text="No pending administrations."
                               FontSize="11" TextColor="{StaticResource Homepage_Font_Secondary}"
                               Margin="4,0"/>
                    </CollectionView.EmptyView>
                    <CollectionView.ItemsLayout>
                        <LinearItemsLayout Orientation="Vertical" ItemSpacing="2"/>
                    </CollectionView.ItemsLayout>
                    <CollectionView.ItemTemplate>
                        <DataTemplate>
                            <Grid ColumnDefinitions="*,Auto,Auto" Padding="4,2">
                                <Label Text="{Binding ResidentName}"
                                       FontSize="12" FontAttributes="Bold"
                                       TextColor="{StaticResource Homepage_Font_Primary}"
                                       LineBreakMode="TailTruncation"
                                       VerticalOptions="Center"/>
                                <Border Grid.Column="1" Padding="6,2" StrokeThickness="0"
                                        BackgroundColor="{StaticResource Alert_Warning}"
                                        Margin="4,0"
                                        IsVisible="{Binding PendingCount, Converter={StaticResource IntPositiveConverter}}">
                                    <Border.StrokeShape><RoundRectangle CornerRadius="4"/></Border.StrokeShape>
                                    <Label Text="{Binding PendingCount, StringFormat='{0} pending'}"
                                           FontSize="10" FontAttributes="Bold"
                                           TextColor="{StaticResource Button_Font_Secondary}"/>
                                </Border>
                                <Border Grid.Column="2" Padding="6,2" StrokeThickness="0"
                                        BackgroundColor="{StaticResource Alert_Error}"
                                        IsVisible="{Binding MissedCount, Converter={StaticResource IntPositiveConverter}}">
                                    <Border.StrokeShape><RoundRectangle CornerRadius="4"/></Border.StrokeShape>
                                    <Label Text="{Binding MissedCount, StringFormat='{0} missed'}"
                                           FontSize="10" FontAttributes="Bold"
                                           TextColor="{StaticResource Button_Font_Primary}"/>
                                </Border>
                            </Grid>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>

            </VerticalStackLayout>
        </Border>

        <!-- ========== LOW STOCK card (row 0, col 1) ========== -->
        <Border Grid.Row="0" Grid.Column="1"
                Stroke="{StaticResource Homepage_Card_Border}"
                StrokeThickness="1"
                BackgroundColor="{StaticResource Homepage_Card_Background}"
                Padding="12">
            <Border.StrokeShape>
                <RoundRectangle CornerRadius="12"/>
            </Border.StrokeShape>

            <VerticalStackLayout Spacing="6">
                <Grid ColumnDefinitions="*,Auto">
                    <HorizontalStackLayout Spacing="6">
                        <Border Padding="6,3" StrokeThickness="0"
                                BackgroundColor="{StaticResource Alert_Error}">
                            <Border.StrokeShape><RoundRectangle CornerRadius="4"/></Border.StrokeShape>
                            <Label Text="{Binding LowStockCount, StringFormat='Low stock: {0}'}"
                                   FontSize="11" FontAttributes="Bold"
                                   TextColor="{StaticResource Button_Font_Primary}"/>
                        </Border>
                    </HorizontalStackLayout>

                    <Border Grid.Column="1" StrokeThickness="0" HeightRequest="24"
                            BackgroundColor="{StaticResource Button_Icon_Background}">
                        <Border.StrokeShape><RoundRectangle CornerRadius="4"/></Border.StrokeShape>
                        <Label Text="VIEW ALL" FontSize="9" FontAttributes="Bold"
                               TextColor="{StaticResource Button_Font_Primary}"
                               Padding="8,0"
                               VerticalOptions="Center" HorizontalOptions="Center"/>
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnViewInventoryClicked"/>
                        </Border.GestureRecognizers>
                    </Border>
                </Grid>

                <CollectionView ItemsSource="{Binding LowStockTop3}"
                                SelectionMode="None">
                    <CollectionView.EmptyView>
                        <Label Text="No low stock items."
                               FontSize="11" TextColor="{StaticResource Homepage_Font_Secondary}"
                               Margin="4,0"/>
                    </CollectionView.EmptyView>
                    <CollectionView.ItemsLayout>
                        <LinearItemsLayout Orientation="Vertical" ItemSpacing="2"/>
                    </CollectionView.ItemsLayout>
                    <CollectionView.ItemTemplate>
                        <DataTemplate>
                            <Grid ColumnDefinitions="*,Auto" Padding="4,1">
                                <VerticalStackLayout Spacing="0">
                                    <Label Text="{Binding MedName}"
                                           FontSize="11" FontAttributes="Bold"
                                           TextColor="{StaticResource Homepage_Font_Primary}"
                                           LineBreakMode="TailTruncation"/>
                                    <Label Text="{Binding Detail}"
                                           FontSize="10"
                                           TextColor="{StaticResource Alert_Error}"/>
                                </VerticalStackLayout>
                                <Label Grid.Column="1"
                                       Text="{Binding ResidentName}"
                                       FontSize="10"
                                       TextColor="{StaticResource Homepage_Font_Secondary}"
                                       VerticalOptions="Center"
                                       IsVisible="{Binding ResidentName, Converter={StaticResource StringNotEmptyConverter}}"/>
                            </Grid>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>
            </VerticalStackLayout>
        </Border>

        <!-- ========== EXPIRING SOON card (row 0, col 2) ========== -->
        <Border Grid.Row="0" Grid.Column="2"
                Stroke="{StaticResource Homepage_Card_Border}"
                StrokeThickness="1"
                BackgroundColor="{StaticResource Homepage_Card_Background}"
                Padding="12">
            <Border.StrokeShape>
                <RoundRectangle CornerRadius="12"/>
            </Border.StrokeShape>

            <VerticalStackLayout Spacing="6">
                <Grid ColumnDefinitions="*,Auto">
                    <HorizontalStackLayout Spacing="6">
                        <Border Padding="6,3" StrokeThickness="0"
                                BackgroundColor="{StaticResource Alert_Warning}">
                            <Border.StrokeShape><RoundRectangle CornerRadius="4"/></Border.StrokeShape>
                            <Label Text="{Binding ExpiringSoonCount, StringFormat='Expiring in 30 days: {0}'}"
                                   FontSize="11" FontAttributes="Bold"
                                   TextColor="{StaticResource Button_Font_Secondary}"/>
                        </Border>
                    </HorizontalStackLayout>

                    <Border Grid.Column="1" StrokeThickness="0" HeightRequest="24"
                            BackgroundColor="{StaticResource Button_Icon_Background}">
                        <Border.StrokeShape><RoundRectangle CornerRadius="4"/></Border.StrokeShape>
                        <Label Text="VIEW ALL" FontSize="9" FontAttributes="Bold"
                               TextColor="{StaticResource Button_Font_Primary}"
                               Padding="8,0"
                               VerticalOptions="Center" HorizontalOptions="Center"/>
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnViewInventoryClicked"/>
                        </Border.GestureRecognizers>
                    </Border>
                </Grid>

                <CollectionView ItemsSource="{Binding ExpiringSoonTop3}"
                                SelectionMode="None">
                    <CollectionView.EmptyView>
                        <Label Text="No medications expiring soon."
                               FontSize="11" TextColor="{StaticResource Homepage_Font_Secondary}"
                               Margin="4,0"/>
                    </CollectionView.EmptyView>
                    <CollectionView.ItemsLayout>
                        <LinearItemsLayout Orientation="Vertical" ItemSpacing="2"/>
                    </CollectionView.ItemsLayout>
                    <CollectionView.ItemTemplate>
                        <DataTemplate>
                            <Grid ColumnDefinitions="*,Auto" Padding="4,1">
                                <VerticalStackLayout Spacing="0">
                                    <Label Text="{Binding MedName}"
                                           FontSize="11" FontAttributes="Bold"
                                           TextColor="{StaticResource Homepage_Font_Primary}"
                                           LineBreakMode="TailTruncation"/>
                                    <Label Text="{Binding Detail}"
                                           FontSize="10"
                                           TextColor="{StaticResource Alert_Warning}"/>
                                </VerticalStackLayout>
                                <Label Grid.Column="1"
                                       Text="{Binding ResidentName}"
                                       FontSize="10"
                                       TextColor="{StaticResource Homepage_Font_Secondary}"
                                       VerticalOptions="Center"
                                       IsVisible="{Binding ResidentName, Converter={StaticResource StringNotEmptyConverter}}"/>
                            </Grid>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>
            </VerticalStackLayout>
        </Border>

        <!-- ========== Search by day, time & name (row 1, cols 1-2) ========== -->
        <Border Grid.Row="1" Grid.Column="1" Grid.ColumnSpan="2"
                Stroke="{StaticResource Homepage_Card_Border}"
                StrokeThickness="1"
                BackgroundColor="{StaticResource Homepage_Card_Background}"
                Padding="12">
            <Border.StrokeShape>
                <RoundRectangle CornerRadius="12" />
            </Border.StrokeShape>

            <Grid RowDefinitions="Auto,Auto" RowSpacing="8">

                <!-- Header -->
                <Label Grid.Row="0"
                       Text="Search by day, time &amp; name"
                       FontAttributes="Bold"
                       FontSize="16"
                       TextColor="{StaticResource Homepage_Font_Primary}" />

                <!-- Controls row: Name | Day | Hour | Min | Search | Clear -->
                <Grid Grid.Row="1"
                      ColumnDefinitions="*,100,70,70,Auto,Auto"
                      ColumnSpacing="8">

                    <!-- Resident Name -->
                    <VerticalStackLayout Grid.Column="0">
                        <Label Text="Resident name" FontSize="11" TextColor="{StaticResource Homepage_Font_Primary}" />
                        <Entry x:Name="ResidentSearchEntry"
                               Placeholder="Search by name"
                               PlaceholderColor="{StaticResource Placeholder_Font_Secondary}"
                               TextColor="{StaticResource Homepage_Font_Primary}"
                               ClearButtonVisibility="WhileEditing"
                               ReturnType="Search"
                               Completed="OnSearchClicked" />
                    </VerticalStackLayout>

                    <!-- Day Picker -->
                    <VerticalStackLayout Grid.Column="1">
                        <Label Text="Day" FontSize="11" TextColor="{StaticResource Homepage_Font_Primary}" />
                        <Picker x:Name="DayPicker">
                            <Picker.Items>
                                <x:String>Mon</x:String>
                                <x:String>Tue</x:String>
                                <x:String>Wed</x:String>
                                <x:String>Thu</x:String>
                                <x:String>Fri</x:String>
                                <x:String>Sat</x:String>
                                <x:String>Sun</x:String>
                            </Picker.Items>
                        </Picker>
                    </VerticalStackLayout>

                    <!-- Hour Picker -->
                    <VerticalStackLayout Grid.Column="2">
                        <Label Text="Hour" FontSize="11" TextColor="{StaticResource Homepage_Font_Primary}" />
                        <Picker x:Name="HourPicker">
                            <Picker.Items>
                                <x:String>0</x:String><x:String>1</x:String><x:String>2</x:String><x:String>3</x:String>
                                <x:String>4</x:String><x:String>5</x:String><x:String>6</x:String><x:String>7</x:String>
                                <x:String>8</x:String><x:String>9</x:String><x:String>10</x:String><x:String>11</x:String>
                                <x:String>12</x:String><x:String>13</x:String><x:String>14</x:String><x:String>15</x:String>
                                <x:String>16</x:String><x:String>17</x:String><x:String>18</x:String><x:String>19</x:String>
                                <x:String>20</x:String><x:String>21</x:String><x:String>22</x:String><x:String>23</x:String>
                            </Picker.Items>
                        </Picker>
                    </VerticalStackLayout>

                    <!-- Min Picker -->
                    <VerticalStackLayout Grid.Column="3">
                        <Label Text="Min" FontSize="11" TextColor="{StaticResource Homepage_Font_Primary}" />
                        <Picker x:Name="MinutePicker">
                            <Picker.Items>
                                <x:String>00</x:String>
                                <x:String>15</x:String>
                                <x:String>30</x:String>
                                <x:String>45</x:String>
                            </Picker.Items>
                        </Picker>
                    </VerticalStackLayout>

                    <!-- Search Button -->
                    <Border Grid.Column="4" StrokeThickness="0" HeightRequest="28" VerticalOptions="End" Margin="0,0,0,4" BackgroundColor="{StaticResource Button_Icon_Background}">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="4"/>
                        </Border.StrokeShape>
                        <Grid ColumnDefinitions="32,Auto" Margin="0" InputTransparent="True">
                            <Image Grid.Column="0" Source="icons8_search_100.png" HeightRequest="16" WidthRequest="16" HorizontalOptions="Center" VerticalOptions="Center"/>
                            <Border Grid.Column="1" BackgroundColor="{StaticResource Button_View}" Padding="10,0" StrokeThickness="0" InputTransparent="True">
                                <Label Text="SEARCH" TextColor="{StaticResource Button_Font_Primary}" FontSize="11" VerticalOptions="Center" FontAttributes="Bold"/>
                            </Border>
                        </Grid>
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnSearchClicked"/>
                        </Border.GestureRecognizers>
                    </Border>

                    <!-- Clear Button -->
                    <Border Grid.Column="5" StrokeThickness="0" HeightRequest="28" VerticalOptions="End" Margin="0,0,0,4" BackgroundColor="{StaticResource Button_Icon_Background}">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="4"/>
                        </Border.StrokeShape>
                        <Grid ColumnDefinitions="32,Auto" Margin="0" InputTransparent="True">
                            <Image Grid.Column="0" Source="icons8_clear_100.png" HeightRequest="16" WidthRequest="16" HorizontalOptions="Center" VerticalOptions="Center"/>
                            <Border Grid.Column="1" BackgroundColor="{StaticResource Button_Cancel}" Padding="10,0" StrokeThickness="0" InputTransparent="True">
                                <Label Text="CLEAR" TextColor="{StaticResource Button_Font_Primary}" FontSize="11" VerticalOptions="Center" FontAttributes="Bold"/>
                            </Border>
                        </Grid>
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnClearDayTimeClicked"/>
                        </Border.GestureRecognizers>
                    </Border>
                </Grid>
            </Grid>
        </Border>

        <!-- ========== Row 2: Medications list (spans all 3 columns) ========== -->
        <Grid Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="3"
              RowDefinitions="Auto,*" RowSpacing="8">

            <Label Text="Medications"
                   FontAttributes="Bold"
                   FontSize="18"
                   TextColor="{StaticResource Homepage_Font_Primary}" />

            <CollectionView Grid.Row="1"
                            x:Name="MedList"
                            ItemsSource="{Binding Medications}"
                            SelectionMode="Single"
                            SelectionChanged="OnSelectionChanged">

                <CollectionView.ItemsLayout>
                    <LinearItemsLayout Orientation="Vertical" ItemSpacing="6" />
                </CollectionView.ItemsLayout>

                <CollectionView.ItemTemplate>
                    <DataTemplate x:DataType="model:Medication">
                        <Border Padding="16,12"
                                BackgroundColor="{StaticResource Homepage_Card_Background}"
                                Stroke="{StaticResource Accent_Teal}"
                                StrokeThickness="1">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="12" />
                            </Border.StrokeShape>

                            <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="12">

                                <!-- Col 0: Resident name -->
                                <Label Grid.Column="0"
                                       Text="{Binding ResidentName}"
                                       FontSize="17" FontAttributes="Bold"
                                       TextColor="{StaticResource Homepage_Font_Primary}"
                                       VerticalOptions="Center" />

                                <!-- Col 1: Med details -->
                                <Label Grid.Column="1" FontSize="15"
                                       TextColor="{StaticResource Homepage_Font_Primary}"
                                       VerticalOptions="Center"
                                       LineBreakMode="TailTruncation">
                                    <Label.FormattedText>
                                        <FormattedString>
                                            <Span Text="{Binding MedName}" FontAttributes="Bold" />
                                            <Span Text=", " />
                                            <Span Text="{Binding Quantity}" />
                                            <Span Text=" " />
                                            <Span Text="{Binding QuantityUnit}" />
                                            <Span Text=" · " TextColor="{StaticResource Accent_Teal}" />
                                            <Span Text="{Binding Usage}" TextColor="{StaticResource Accent_Teal}" />
                                        </FormattedString>
                                    </Label.FormattedText>
                                </Label>

                                <!-- Col 2: Timeslot chips -->
                                <HorizontalStackLayout Grid.Column="2" Spacing="12"
                                                       VerticalOptions="Center">
                                    <!-- Slot 1 -->
                                    <HorizontalStackLayout Spacing="0">
                                        <Label Text="{Binding TodayTime1, StringFormat='{}{0:hh\\:mm}'}"
                                               FontSize="18" FontAttributes="Bold"
                                               TextColor="{StaticResource Homepage_Font_Primary}"
                                               VerticalOptions="Center" />
                                        <CheckBox IsChecked="{Binding IsDone}"
                                                  CheckedChanged="OnDoneCheckedChanged"
                                                  VerticalOptions="Center"
                                                  Margin="0,0,-10,0" />
                                    </HorizontalStackLayout>

                                    <!-- Slot 2 -->
                                    <HorizontalStackLayout Spacing="0"
                                                           IsVisible="{Binding HasSlot2}">
                                        <Label Text="{Binding TodayTime2, StringFormat='{}{0:hh\\:mm}'}"
                                               FontSize="18" FontAttributes="Bold"
                                               TextColor="{StaticResource Homepage_Font_Primary}"
                                               VerticalOptions="Center" />
                                        <CheckBox IsChecked="{Binding IsDoneSlot2}"
                                                  CheckedChanged="OnDoneCheckedChanged"
                                                  VerticalOptions="Center"
                                                  Margin="0,0,-10,0" />
                                    </HorizontalStackLayout>

                                    <!-- Slot 3 -->
                                    <HorizontalStackLayout Spacing="0"
                                                           IsVisible="{Binding HasSlot3}">
                                        <Label Text="{Binding TodayTime3, StringFormat='{}{0:hh\\:mm}'}"
                                               FontSize="18" FontAttributes="Bold"
                                               TextColor="{StaticResource Homepage_Font_Primary}"
                                               VerticalOptions="Center" />
                                        <CheckBox IsChecked="{Binding IsDoneSlot3}"
                                                  CheckedChanged="OnDoneCheckedChanged"
                                                  VerticalOptions="Center"
                                                  Margin="0,0,-10,0" />
                                    </HorizontalStackLayout>
                                </HorizontalStackLayout>

                            </Grid>
                        </Border>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>
        </Grid>

    </Grid>
</pages:AuthPage>
