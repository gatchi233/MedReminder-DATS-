<?xml version="1.0" encoding="utf-8" ?>
<pages:AuthPage
    x:Name="Root"
    x:Class="CareHub.Pages.Desktop.MarPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:pages="clr-namespace:CareHub.Pages"
    Title="MAR"
    BackgroundColor="{StaticResource Mar_Main_Background}">

    <ScrollView>
        <Grid Padding="16" RowDefinitions="Auto,Auto,Auto,Auto,*" RowSpacing="12">

            <Grid ColumnDefinitions="*,Auto,Auto" ColumnSpacing="8">
                <VerticalStackLayout Spacing="2">
                    <Label Text="MEDICATION ADMINISTRATION RECORD"
                           FontSize="11"
                           FontAttributes="Bold"
                           CharacterSpacing="1.5"
                           TextColor="{StaticResource Mar_Font_Secondary}" />
                    <Label Text="{Binding StatusMessage}"
                           FontSize="14"
                           FontAttributes="Bold"
                           TextColor="{StaticResource Mar_Font_Primary}" />
                </VerticalStackLayout>

                <Border Grid.Column="1"
                        Padding="8,4"
                        StrokeThickness="0"
                        BackgroundColor="{StaticResource Alert_Warning}"
                        IsVisible="{Binding IsOffline}">
                    <Border.StrokeShape><RoundRectangle CornerRadius="8" /></Border.StrokeShape>
                    <Label Text="OFFLINE" FontSize="10" FontAttributes="Bold" TextColor="{StaticResource Button_Font_Primary}" />
                </Border>

                <Border Grid.Column="2"
                        StrokeThickness="0"
                        HeightRequest="30"
                        BackgroundColor="{StaticResource Button_Icon_Background}">
                    <Border.StrokeShape><RoundRectangle CornerRadius="4" /></Border.StrokeShape>
                    <Grid ColumnDefinitions="32,Auto" InputTransparent="True">
                        <Image Grid.Column="0" Source="icons8_close_100.png" HeightRequest="16" WidthRequest="16" HorizontalOptions="Center" VerticalOptions="Center" />
                        <Border Grid.Column="1" BackgroundColor="{StaticResource Button_Close}" Padding="10,0" StrokeThickness="0">
                            <Label Text="CLOSE" TextColor="{StaticResource Button_Font_Primary}" FontSize="11" FontAttributes="Bold" VerticalOptions="Center" />
                        </Border>
                    </Grid>
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnCloseClicked" />
                    </Border.GestureRecognizers>
                </Border>
            </Grid>

            <Border Grid.Row="1"
                    Padding="12"
                    BackgroundColor="{StaticResource Mar_Card_Background}"
                    Stroke="{StaticResource Mar_Card_Border}"
                    StrokeThickness="1">
                <Border.StrokeShape><RoundRectangle CornerRadius="12" /></Border.StrokeShape>
                <Grid ColumnDefinitions="*,*,Auto,Auto,Auto" RowDefinitions="Auto,Auto" ColumnSpacing="10" RowSpacing="10">
                    <Picker Title="Resident"
                            ItemsSource="{Binding Residents}"
                            ItemDisplayBinding="{Binding ResidentName}"
                            SelectedItem="{Binding SelectedResident}" />
                    <Picker Grid.Column="1"
                            Title="Medication"
                            ItemsSource="{Binding ResidentMedications}"
                            ItemDisplayBinding="{Binding MedName}"
                            SelectedItem="{Binding SelectedMedication}" />

                    <DatePicker Grid.Column="2" Date="{Binding FromLocalDate}" />
                    <DatePicker Grid.Column="3" Date="{Binding ToLocalDate}" />

                    <VerticalStackLayout Grid.Column="4" Spacing="4" HorizontalOptions="End">
                        <CheckBox IsChecked="{Binding IncludeVoided}" />
                        <Label Text="Include Voided" FontSize="10" TextColor="{StaticResource Mar_Font_Secondary}" HorizontalTextAlignment="Center" />
                    </VerticalStackLayout>

                    <Button Grid.Row="1" Text="Refresh" Command="{Binding RefreshCommand}" />
                    <Button Grid.Row="1" Grid.Column="1" Text="Refresh Report" Command="{Binding RefreshReportCommand}" />
                </Grid>
            </Border>

            <Border Grid.Row="2"
                    Padding="12"
                    BackgroundColor="{StaticResource Mar_Card_Background}"
                    Stroke="{StaticResource Mar_Card_Border}"
                    StrokeThickness="1"
                    IsVisible="{Binding CanEditEntries}">
                <Border.StrokeShape><RoundRectangle CornerRadius="12" /></Border.StrokeShape>
                <Grid RowDefinitions="Auto,Auto,Auto,Auto" ColumnDefinitions="*,*,*,*" RowSpacing="10" ColumnSpacing="10">
                    <Label Text="Create MAR Entry" FontAttributes="Bold" FontSize="14" TextColor="{StaticResource Mar_Font_Primary}" Grid.ColumnSpan="4" />

                    <Picker Grid.Row="1"
                            Title="Status"
                            ItemsSource="{Binding StatusOptions}"
                            SelectedItem="{Binding SelectedStatus}" />
                    <Entry Grid.Row="1" Grid.Column="1" Text="{Binding DoseQuantity}" Keyboard="Numeric" Placeholder="Dose quantity" />
                    <Entry Grid.Row="1" Grid.Column="2" Text="{Binding DoseUnit}" Placeholder="Dose unit" />
                    <Entry Grid.Row="1" Grid.Column="3" Text="{Binding Notes}" Placeholder="Notes" />

                    <DatePicker Grid.Row="2" Date="{Binding AdministeredLocalDate}" />
                    <TimePicker Grid.Row="2" Grid.Column="1" Time="{Binding AdministeredLocalTime}" />
                    <DatePicker Grid.Row="2" Grid.Column="2" Date="{Binding ScheduledLocalDate}" />
                    <TimePicker Grid.Row="2" Grid.Column="3" Time="{Binding ScheduledLocalTime}" />

                    <Button Grid.Row="3" Grid.ColumnSpan="4" Text="Create MAR Entry" Command="{Binding CreateEntryCommand}" />
                </Grid>
            </Border>

            <Border Grid.Row="3"
                    Padding="12"
                    BackgroundColor="{StaticResource Mar_Card_Background}"
                    Stroke="{StaticResource Mar_Card_Border}"
                    StrokeThickness="1"
                    IsVisible="{Binding CanViewReport}">
                <Border.StrokeShape><RoundRectangle CornerRadius="12" /></Border.StrokeShape>
                <Grid RowDefinitions="Auto,Auto,Auto,*" RowSpacing="8">
                    <Label Text="Report" FontAttributes="Bold" FontSize="14" TextColor="{StaticResource Mar_Font_Primary}" />
                    <Label Grid.Row="1" Text="{Binding ReportWindowText}" FontSize="12" TextColor="{StaticResource Mar_Font_Secondary}" />
                    <Grid Grid.Row="2" ColumnDefinitions="*,*,*,*,*,*" ColumnSpacing="8">
                        <Label Text="{Binding ReportSummary.TotalEntries, StringFormat='Total: {0}'}" FontSize="11" />
                        <Label Grid.Column="1" Text="{Binding ReportSummary.GivenCount, StringFormat='Given: {0}'}" FontSize="11" />
                        <Label Grid.Column="2" Text="{Binding ReportSummary.RefusedCount, StringFormat='Refused: {0}'}" FontSize="11" />
                        <Label Grid.Column="3" Text="{Binding ReportSummary.HeldCount, StringFormat='Held: {0}'}" FontSize="11" />
                        <Label Grid.Column="4" Text="{Binding ReportSummary.MissedCount, StringFormat='Missed: {0}'}" FontSize="11" />
                        <Label Grid.Column="5" Text="{Binding ReportSummary.NotAvailableCount, StringFormat='Not Available: {0}'}" FontSize="11" />
                    </Grid>
                    <CollectionView Grid.Row="3" ItemsSource="{Binding ReportLines}" SelectionMode="None" HeightRequest="180">
                        <CollectionView.ItemTemplate>
                            <DataTemplate>
                                <VerticalStackLayout Spacing="2" Padding="0,4">
                                    <Label Text="{Binding Summary}" FontSize="12" FontAttributes="Bold" />
                                    <Label Text="{Binding Detail}" FontSize="11" TextColor="{StaticResource Mar_Font_Secondary}" />
                                </VerticalStackLayout>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>
                </Grid>
            </Border>

            <Border Grid.Row="4"
                    Padding="12"
                    BackgroundColor="{StaticResource Mar_Card_Background}"
                    Stroke="{StaticResource Mar_Card_Border}"
                    StrokeThickness="1">
                <Border.StrokeShape><RoundRectangle CornerRadius="12" /></Border.StrokeShape>
                <Grid RowDefinitions="Auto,Auto,*" RowSpacing="8">
                    <Grid ColumnDefinitions="*,Auto,*" ColumnSpacing="8">
                        <Label Text="MAR List" FontAttributes="Bold" FontSize="14" TextColor="{StaticResource Mar_Font_Primary}" />
                        <ActivityIndicator Grid.Column="1" IsRunning="{Binding IsBusy}" IsVisible="{Binding IsBusy}" />
                        <Entry Grid.Column="2"
                               Text="{Binding VoidReason}"
                               Placeholder="Void reason for selected action"
                               IsVisible="{Binding CanEditEntries}" />
                    </Grid>

                    <Label Grid.Row="1"
                           Text="Create/void actions are restricted to nurses."
                           FontSize="11"
                           TextColor="{StaticResource Mar_Font_Secondary}" />

                    <CollectionView Grid.Row="2" ItemsSource="{Binding Entries}" SelectionMode="None">
                        <CollectionView.EmptyView>
                            <Label Text="No MAR entries in the selected range." TextColor="{StaticResource Mar_Font_Secondary}" />
                        </CollectionView.EmptyView>
                        <CollectionView.ItemsLayout>
                            <LinearItemsLayout Orientation="Vertical" ItemSpacing="10" />
                        </CollectionView.ItemsLayout>
                        <CollectionView.ItemTemplate>
                            <DataTemplate>
                                <Border Padding="12"
                                        BackgroundColor="{StaticResource Mar_Main_Background}"
                                        Stroke="{StaticResource Mar_Card_Border}"
                                        StrokeThickness="1">
                                    <Border.StrokeShape><RoundRectangle CornerRadius="10" /></Border.StrokeShape>
                                    <Grid RowDefinitions="Auto,Auto,Auto,Auto" ColumnDefinitions="*,Auto" RowSpacing="6">
                                        <Label Text="{Binding ResidentName}" FontAttributes="Bold" FontSize="13" TextColor="{StaticResource Mar_Font_Primary}" />
                                        <Border Grid.Column="1" Padding="10,4" StrokeThickness="0" BackgroundColor="{Binding Status, Converter={StaticResource MarStatusToColorConverter}}">
                                            <Border.StrokeShape><RoundRectangle CornerRadius="10" /></Border.StrokeShape>
                                            <Label Text="{Binding Status}" FontSize="10" FontAttributes="Bold" TextColor="{StaticResource Button_Font_Primary}" />
                                        </Border>

                                        <Label Grid.Row="1" Text="{Binding MedicationName}" FontSize="13" TextColor="{StaticResource Mar_Font_Primary}" />
                                        <Label Grid.Row="1" Grid.Column="1" Text="{Binding DoseDisplay}" FontSize="12" TextColor="{StaticResource Mar_Font_Secondary}" />

                                        <VerticalStackLayout Grid.Row="2" Grid.ColumnSpan="2" Spacing="2">
                                            <Label Text="{Binding AdministeredDisplay, StringFormat='Administered: {0}'}" FontSize="11" TextColor="{StaticResource Mar_Font_Secondary}" />
                                            <Label Text="{Binding ScheduledDisplay, StringFormat='Scheduled: {0}'}" FontSize="11" TextColor="{StaticResource Mar_Font_Secondary}" />
                                            <Label Text="{Binding RecordedBy, StringFormat='Recorded by: {0}'}" FontSize="11" TextColor="{StaticResource Mar_Font_Secondary}" />
                                            <Label Text="{Binding Notes}" FontSize="11" TextColor="{StaticResource Mar_Font_Secondary}" IsVisible="{Binding Notes, Converter={StaticResource StringNotEmptyConverter}}" />
                                            <Label Text="{Binding VoidDisplay}" FontSize="11" TextColor="{StaticResource Alert_Error}" IsVisible="{Binding IsVoided}" />
                                        </VerticalStackLayout>

                                        <Button Grid.Row="3"
                                                Grid.ColumnSpan="2"
                                                Text="Void Entry"
                                                Clicked="OnVoidClicked"
                                                CommandParameter="{Binding .}"
                                                IsVisible="{Binding ShowVoidButton}" />
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>
                </Grid>
            </Border>
        </Grid>
    </ScrollView>
</pages:AuthPage>
