<?xml version="1.0" encoding="utf-8" ?>
<pages:AuthPage
    x:Name="Root"
    x:Class="CareHub.Pages.Desktop.MedicationOrdersPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:pages="clr-namespace:CareHub.Pages"
    Title="Medication Orders"
    BackgroundColor="{StaticResource Medication_Main_Background}">

    <ScrollView>
        <Grid Padding="16" RowDefinitions="Auto,Auto,Auto,*" RowSpacing="12">

            <Grid ColumnDefinitions="*,Auto,Auto,Auto" ColumnSpacing="8">
                <VerticalStackLayout Spacing="2">
                    <Label Text="MEDICATION ORDERS"
                           FontSize="11"
                           FontAttributes="Bold"
                           CharacterSpacing="1.5"
                           TextColor="{StaticResource Medication_Font_Secondary}" />
                    <Label Text="{Binding StatusMessage}"
                           FontSize="14"
                           FontAttributes="Bold"
                           TextColor="{StaticResource Medication_Font_Primary}" />
                </VerticalStackLayout>

                <Border Grid.Column="1"
                        StrokeThickness="0"
                        HeightRequest="30"
                        BackgroundColor="{StaticResource Button_Icon_Background}"
                        IsVisible="{Binding IsNurseOrAdmin}">
                    <Border.StrokeShape><RoundRectangle CornerRadius="4" /></Border.StrokeShape>
                    <Grid ColumnDefinitions="32,Auto" InputTransparent="True">
                        <Image Grid.Column="0" Source="icons8_add_100.png" HeightRequest="16" WidthRequest="16" HorizontalOptions="Center" VerticalOptions="Center" />
                        <Border Grid.Column="1" BackgroundColor="{StaticResource Button_Add}" Padding="10,0" StrokeThickness="0">
                            <Label Text="NEW ORDER" TextColor="{StaticResource Button_Font_Primary}" FontSize="11" FontAttributes="Bold" VerticalOptions="Center" />
                        </Border>
                    </Grid>
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnNewOrderClicked" />
                    </Border.GestureRecognizers>
                </Border>

                <Border Grid.Column="2"
                        StrokeThickness="0"
                        HeightRequest="30"
                        BackgroundColor="{StaticResource Button_Icon_Background}">
                    <Border.StrokeShape><RoundRectangle CornerRadius="4" /></Border.StrokeShape>
                    <Grid ColumnDefinitions="32,Auto" InputTransparent="True">
                        <Image Grid.Column="0" Source="icons8_updates_100.png" HeightRequest="16" WidthRequest="16" HorizontalOptions="Center" VerticalOptions="Center" />
                        <Border Grid.Column="1" BackgroundColor="{StaticResource Button_Logout}" Padding="10,0" StrokeThickness="0">
                            <Label Text="REFRESH" TextColor="{StaticResource Button_Font_Primary}" FontSize="11" FontAttributes="Bold" VerticalOptions="Center" />
                        </Border>
                    </Grid>
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding RefreshCommand}" />
                    </Border.GestureRecognizers>
                </Border>

                <Border Grid.Column="3"
                        StrokeThickness="0"
                        HeightRequest="30"
                        BackgroundColor="{StaticResource Button_Icon_Background}">
                    <Border.StrokeShape><RoundRectangle CornerRadius="4" /></Border.StrokeShape>
                    <Grid ColumnDefinitions="32,Auto" InputTransparent="True">
                        <Image Grid.Column="0" Source="icons8_close_100.png" HeightRequest="16" WidthRequest="16" HorizontalOptions="Center" VerticalOptions="Center" />
                        <Border Grid.Column="1" BackgroundColor="{StaticResource Button_Cancel}" Padding="10,0" StrokeThickness="0">
                            <Label Text="CLOSE" TextColor="{StaticResource Button_Font_Secondary}" FontSize="11" FontAttributes="Bold" VerticalOptions="Center" />
                        </Border>
                    </Grid>
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnCloseClicked" />
                    </Border.GestureRecognizers>
                </Border>
            </Grid>

            <Border Grid.Row="1"
                    Padding="12"
                    BackgroundColor="{StaticResource Medication_Card_Background}"
                    Stroke="{StaticResource Medication_Card_Border}"
                    StrokeThickness="1">
                <Border.StrokeShape><RoundRectangle CornerRadius="12" /></Border.StrokeShape>
                <Grid ColumnDefinitions="*,Auto,Auto" ColumnSpacing="10">
                    <Picker Title="Filter by medication"
                            ItemsSource="{Binding InventoryMedications}"
                            ItemDisplayBinding="{Binding MedName}"
                            SelectedItem="{Binding SelectedMedication}" />

                    <Border Grid.Column="1"
                            StrokeThickness="0"
                            HeightRequest="30"
                            BackgroundColor="{StaticResource Button_Icon_Background}"
                            IsVisible="{Binding IsMedicationFilterActive}">
                        <Border.StrokeShape><RoundRectangle CornerRadius="4" /></Border.StrokeShape>
                        <Border BackgroundColor="{StaticResource Button_View}" Padding="10,0" StrokeThickness="0">
                            <Label Text="CLEAR FILTER" TextColor="{StaticResource Button_Font_Primary}" FontSize="11" FontAttributes="Bold" VerticalOptions="Center" />
                        </Border>
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding ClearMedicationFilterCommand}" />
                        </Border.GestureRecognizers>
                    </Border>

                    <ActivityIndicator Grid.Column="2"
                                       IsRunning="{Binding IsBusy}"
                                       IsVisible="{Binding IsBusy}"
                                       VerticalOptions="Center" />
                </Grid>
            </Border>

            <Label Grid.Row="2"
                   Text="{Binding SelectedMedicationName}"
                   FontSize="12"
                   TextColor="{StaticResource Medication_Font_Secondary}" />

            <CollectionView Grid.Row="3"
                            ItemsSource="{Binding Orders}"
                            SelectionMode="None">
                <CollectionView.EmptyView>
                    <VerticalStackLayout Padding="20" Spacing="6" VerticalOptions="Center" HorizontalOptions="Center">
                        <Label Text="No orders found."
                               FontAttributes="Bold"
                               FontSize="14"
                               TextColor="{StaticResource Medication_Font_Primary}"
                               HorizontalOptions="Center" />
                        <Label Text="Create an order or clear the medication filter."
                               FontSize="12"
                               TextColor="{StaticResource Medication_Font_Secondary}"
                               HorizontalOptions="Center" />
                    </VerticalStackLayout>
                </CollectionView.EmptyView>

                <CollectionView.ItemsLayout>
                    <LinearItemsLayout Orientation="Vertical" ItemSpacing="10" />
                </CollectionView.ItemsLayout>

                <CollectionView.ItemTemplate>
                    <DataTemplate>
                        <Border Padding="14,12"
                                BackgroundColor="{StaticResource Medication_Card_Background}"
                                Stroke="{StaticResource Medication_Card_Border}"
                                StrokeThickness="1">
                            <Border.StrokeShape><RoundRectangle CornerRadius="10" /></Border.StrokeShape>

                            <Grid RowDefinitions="Auto,Auto,Auto,Auto,Auto" RowSpacing="8">
                                <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
                                    <Label Text="{Binding MedicationName}"
                                           FontAttributes="Bold"
                                           FontSize="15"
                                           TextColor="{StaticResource Medication_Font_Primary}" />
                                    <Border Grid.Column="1" Padding="8,3" StrokeThickness="0" BackgroundColor="{Binding StatusBadgeColor}">
                                        <Border.StrokeShape><RoundRectangle CornerRadius="4" /></Border.StrokeShape>
                                        <Label Text="{Binding StatusDisplay}" FontSize="10" FontAttributes="Bold" TextColor="White" />
                                    </Border>
                                </Grid>

                                <Label Grid.Row="1"
                                       Text="{Binding QuantityText}"
                                       FontSize="12"
                                       TextColor="{StaticResource Medication_Font_Secondary}" />

                                <Label Grid.Row="2"
                                       Text="{Binding Notes}"
                                       FontSize="12"
                                       TextColor="{StaticResource Medication_Font_Secondary}"
                                       IsVisible="{Binding Notes, Converter={StaticResource StringNotEmptyConverter}}" />

                                <VerticalStackLayout Grid.Row="3" Spacing="6">
                                    <Label Text="{Binding RequestedLine}" FontSize="11" TextColor="{StaticResource Medication_Font_Secondary}" />
                                    <Label Text="{Binding OrderedLine}" FontSize="11" TextColor="{StaticResource Medication_Font_Secondary}" IsVisible="{Binding ShowOrderedRow}" />
                                    <Label Text="{Binding ThirdLineText}" FontSize="11" TextColor="{StaticResource Medication_Font_Secondary}" IsVisible="{Binding ShowThirdRow}" />
                                    <Label Text="{Binding ExpiryLine}" FontSize="11" TextColor="{StaticResource Medication_Font_Secondary}" IsVisible="{Binding ShowExpiry}" />
                                </VerticalStackLayout>

                                <HorizontalStackLayout Grid.Row="4"
                                                       Spacing="8"
                                                       IsVisible="{Binding Source={x:Reference Root}, Path=BindingContext.IsNurseOrAdmin}">
                                    <Button Text="ORDERED"
                                            Clicked="OnMarkOrderedClicked"
                                            CommandParameter="{Binding .}"
                                            IsVisible="{Binding ShowMarkOrdered}" />
                                    <Button Text="RECEIVED"
                                            Clicked="OnReceiveClicked"
                                            CommandParameter="{Binding .}"
                                            IsVisible="{Binding ShowMarkReceived}" />
                                    <Button Text="CANCEL"
                                            Clicked="OnCancelClicked"
                                            CommandParameter="{Binding .}"
                                            IsVisible="{Binding ShowCancelRequest}" />
                                    <Button Text="CANCEL"
                                            Clicked="OnCancelClicked"
                                            CommandParameter="{Binding .}"
                                            IsVisible="{Binding ShowCancelOrder}" />
                                </HorizontalStackLayout>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>
        </Grid>
    </ScrollView>
</pages:AuthPage>
