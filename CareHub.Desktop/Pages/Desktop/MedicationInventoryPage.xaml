<?xml version="1.0" encoding="utf-8" ?>
<pages:AuthPage
    x:Name="Root"
    x:Class="CareHub.Pages.Desktop.MedicationInventoryPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:pages="clr-namespace:CareHub.Pages"
    Title="Medication Inventory"
    BackgroundColor="{StaticResource Medication_Main_Background}">


    <Grid Padding="16" RowDefinitions="Auto,Auto,*" RowSpacing="12">

        <!-- Top bar: Search + action Button (match ResidentsPage layout) -->
        <Grid ColumnDefinitions="*,Auto" ColumnSpacing="10">

            <SearchBar x:Name="MedSearchBar"
                       Placeholder="Search medication..."
                       TextChanged="OnFilterChanged" />

            <HorizontalStackLayout Grid.Column="1" Spacing="8">

                <!-- Orders -->
                <Border StrokeThickness="0" HeightRequest="28" BackgroundColor="{StaticResource Button_Icon_Background}">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="4"/>
                    </Border.StrokeShape>

                    <Grid ColumnDefinitions="32,Auto" Margin="0" InputTransparent="True">
                        <Image Grid.Column="0" Source="icons8_basketadd_100.png"
                               HeightRequest="16" WidthRequest="16"
                               HorizontalOptions="Center" VerticalOptions="Center"/>

                        <Border Grid.Column="1" BackgroundColor="{StaticResource Button_Create}"
                                Padding="10,0" StrokeThickness="0">
                            <Label Text="NEW ORDER"
                                   TextColor="{StaticResource Button_Font_Primary}" FontSize="11"
                                   VerticalOptions="Center" FontAttributes="Bold"/>
                        </Border>
                    </Grid>

                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnOrdersClicked" />
                    </Border.GestureRecognizers>
                </Border>

                <!-- Pending Orders -->
                <Border StrokeThickness="0" HeightRequest="28" BackgroundColor="{StaticResource Button_Icon_Background}">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="4"/>
                    </Border.StrokeShape>

                    <Grid ColumnDefinitions="32,Auto" Margin="0" InputTransparent="True">
                        <Image Grid.Column="0" Source="icons8_basketpaid_100.png"
                               HeightRequest="16" WidthRequest="16"
                               HorizontalOptions="Center" VerticalOptions="Center"/>

                        <Border Grid.Column="1" BackgroundColor="{StaticResource Button_View}"
                                Padding="10,0" StrokeThickness="0">
                            <Label Text="PENDING"
                                   TextColor="{StaticResource Button_Font_Primary}" FontSize="11"
                                   VerticalOptions="Center" FontAttributes="Bold"/>
                        </Border>
                    </Grid>

                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnPendingOrdersClicked" />
                    </Border.GestureRecognizers>
                </Border>

                <!-- Sort -->
                <Border StrokeThickness="0" HeightRequest="28" BackgroundColor="{StaticResource Button_Icon_Background}">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="4"/>
                    </Border.StrokeShape>

                    <Grid ColumnDefinitions="32,Auto" Margin="0" InputTransparent="True">
                        <Image Grid.Column="0"
                               Source="icons8_sort_100.png"
                               HeightRequest="16"
                               WidthRequest="16"
                               HorizontalOptions="Center"
                               VerticalOptions="Center"/>

                        <Border Grid.Column="1"
                                BackgroundColor="{StaticResource Button_View}"
                                Padding="10,0"
                                StrokeThickness="0">
                            <Label Text="SORT"
                                   TextColor="{StaticResource Button_Font_Primary}"
                                   FontSize="11"
                                   VerticalOptions="Center"
                                   FontAttributes="Bold"/>
                        </Border>
                    </Grid>

                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnSortClicked" />
                    </Border.GestureRecognizers>
                </Border>

            </HorizontalStackLayout>
        </Grid>

        <!-- Filter banner -->
        <Border Grid.Row="1" Padding="10,6" StrokeThickness="0"
                BackgroundColor="{StaticResource Alert_Warning}"
                IsVisible="{Binding IsFilterActive, Source={x:Reference Root}}">
            <Border.StrokeShape><RoundRectangle CornerRadius="6"/></Border.StrokeShape>
            <Grid ColumnDefinitions="*,Auto">
                <Label Text="{Binding FilterBannerText, Source={x:Reference Root}}"
                       FontSize="12" FontAttributes="Bold"
                       TextColor="{StaticResource Button_Font_Secondary}"
                       VerticalOptions="Center"/>
                <Border Grid.Column="1" StrokeThickness="0" HeightRequest="24"
                        BackgroundColor="{StaticResource Button_Icon_Background}" Padding="8,0">
                    <Border.StrokeShape><RoundRectangle CornerRadius="4"/></Border.StrokeShape>
                    <Label Text="CLEAR" FontSize="10" FontAttributes="Bold"
                           TextColor="{StaticResource Button_Font_Primary}"
                           VerticalOptions="Center" HorizontalOptions="Center"/>
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnClearFilterClicked"/>
                    </Border.GestureRecognizers>
                </Border>
            </Grid>
        </Border>

        <!-- Inventory list -->
        <CollectionView x:Name="InventoryCollection" Grid.Row="2" ItemsSource="{Binding Items}">

            <CollectionView.EmptyView>
                <Label Text="No inventory items found." 
                       Opacity="0.6" VerticalOptions="Center" />
            </CollectionView.EmptyView>

            <CollectionView.ItemsLayout>
                <LinearItemsLayout Orientation="Vertical" ItemSpacing="6"/>
            </CollectionView.ItemsLayout>

            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <Border Padding="12"
                            BackgroundColor="{StaticResource Medication_Main_Background}"
                            Stroke="{StaticResource Medication_Font_Primary}"
                            StrokeThickness="1">

                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="8"/>
                        </Border.StrokeShape>

                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnCardTapped" CommandParameter="{Binding .}"/>
                        </Border.GestureRecognizers>

                        <Grid ColumnDefinitions="*,Auto"
                              ColumnSpacing="10"
                              RowSpacing="8">

                            <!-- Row 0 -->
                            <HorizontalStackLayout Spacing="12" VerticalOptions="Center">
                                <Label Text="{Binding MedName}" FontSize="18" FontAttributes="Bold" TextColor="{StaticResource Medication_Font_Primary}" />
                                <BoxView WidthRequest="1" HeightRequest="20" Color="{StaticResource Medication_Font_Secondary}" VerticalOptions="Center"/>

                                <Label Text="{Binding QuantityUnit}" FontSize="13" TextColor="{StaticResource Medication_Font_Secondary}" VerticalOptions="Center"/>
                                <BoxView WidthRequest="1" HeightRequest="20" Color="{StaticResource Medication_Font_Secondary}" VerticalOptions="Center"/>
                                <Label Text="{Binding Usage}" FontSize="13" TextColor="{StaticResource Medication_Font_Secondary}" VerticalOptions="Center"/>
                                <BoxView WidthRequest="1" HeightRequest="20" Color="{StaticResource Medication_Font_Secondary}" VerticalOptions="Center"/>

                                <Label FontSize="13" TextColor="{StaticResource Medication_Font_Secondary}" VerticalOptions="Center">
                                    <Label.FormattedText>
                                        <FormattedString>
                                            <Span Text="Stock: "/>
                                            <Span Text="{Binding StockQuantity}"/>
                                            <Span Text=" • "/>
                                            <Span Text="Reorder: "/>
                                            <Span Text="{Binding ReorderLevel}"/>
                                        </FormattedString>
                                    </Label.FormattedText>
                                </Label>
                            </HorizontalStackLayout>

                            <!-- Right side: Low Stock + Adjust + Order -->
                            <HorizontalStackLayout Grid.Column="1" Spacing="8" HorizontalOptions="End" VerticalOptions="Center">

                                <!-- Low stock badge -->

                                <Image Source="icons8_redwarning_100.png"
                                       HeightRequest="22" WidthRequest="22"
                                       IsVisible="{Binding IsLowStock}"
                                       VerticalOptions="Center" />

                                <Border StrokeThickness="0" HeightRequest="28" BackgroundColor="{StaticResource Button_Icon_Background}">
                                    <Border.StrokeShape>
                                        <RoundRectangle CornerRadius="4"/>
                                    </Border.StrokeShape>
                                    <Grid ColumnDefinitions="32,Auto" Margin="0" InputTransparent="True">
                                        <Image Grid.Column="0" Source="icons8_adjust_100.png" HeightRequest="16" WidthRequest="16" HorizontalOptions="Center" VerticalOptions="Center"/>
                                        <Border Grid.Column="1" BackgroundColor="{StaticResource Button_Edit}" Padding="10,0" StrokeThickness="0" InputTransparent="True">
                                            <Label Text="ADJUST" TextColor="{StaticResource Button_Font_Primary}" FontSize="11" VerticalOptions="Center" FontAttributes="Bold"/>
                                        </Border>
                                    </Grid>
                                    <Border.GestureRecognizers>
                                        <TapGestureRecognizer Tapped="OnAdjustClicked" CommandParameter="{Binding .}"/>
                                    </Border.GestureRecognizers>
                                </Border>

                                <!-- Orders -->
                                <Border StrokeThickness="0" HeightRequest="28" BackgroundColor="{StaticResource Button_Icon_Background}">
                                    <Border.StrokeShape>
                                        <RoundRectangle CornerRadius="4"/>
                                    </Border.StrokeShape>
                                    <Grid ColumnDefinitions="32,Auto" Margin="0" InputTransparent="True">
                                        <Image Grid.Column="0" Source="icons8_basketadd_100.png" HeightRequest="16" WidthRequest="16" HorizontalOptions="Center" VerticalOptions="Center"/>
                                        <Border Grid.Column="1" BackgroundColor="{StaticResource Button_Create}" Padding="10,0" StrokeThickness="0" InputTransparent="True">
                                            <Label Text="ORDERS" TextColor="{StaticResource Button_Font_Primary}" FontSize="11" VerticalOptions="Center" FontAttributes="Bold"/>
                                        </Border>
                                    </Grid>
                                    <Border.GestureRecognizers>
                                        <TapGestureRecognizer Tapped="OnDirectOrderClicked" CommandParameter="{Binding .}"/>
                                    </Border.GestureRecognizers>
                                </Border>
                            </HorizontalStackLayout>

                        </Grid>

                    </Border>
                </DataTemplate>
            </CollectionView.ItemTemplate>

        </CollectionView>

    </Grid>
</pages:AuthPage>
